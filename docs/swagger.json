                ],
                "tags": [
                    "user"
                ],
                "summary": "Получение данных пользователя по его id.",
                "parameters": [
                    {
                        "type": "integer",
                        "description": "User ID",
                        "name": "id",
                        "in": "path",
                        "required": true
